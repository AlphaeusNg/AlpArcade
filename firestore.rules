rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in Firebase Auth user (app only offers Google in the UI).
    // Do NOT require sign_in_provider == 'google.com' — that claim is brittle
    // across popup / redirect / token refresh and caused false permission-denied.
    function signedIn() {
      return request.auth != null && request.auth.uid is string;
    }

    function validGame(g) {
      return g in ['tictactoe', 'shooter', 'snake', 'reaction', 'memory', 'tapper'];
    }

    // scores/{uid}_{gameId} — one personal best per user per cabinet
    function validScoreWrite() {
      let d = request.resource.data;
      return signedIn()
        && d.keys().hasAll(['game', 'playerName', 'score', 'rankScore', 'userId'])
        && d.userId is string
        && d.userId == request.auth.uid
        && d.game is string
        && validGame(d.game)
        // Doc id must be exactly {uid}_{game}
        && scoreId == request.auth.uid + '_' + d.game
        && d.playerName is string
        && d.playerName.size() >= 1
        && d.playerName.size() <= 16
        && d.score is number
        && d.score >= 0
        && d.score <= 10000000
        && d.rankScore is number;
    }

    match /scores/{scoreId} {
      allow read: if true;

      allow create: if validScoreWrite();

      allow update: if validScoreWrite()
        && resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    match /players/{uid} {
      allow read: if true;

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 1
        && request.resource.data.username.size() <= 16;

      allow delete: if false;
    }
  }
}
