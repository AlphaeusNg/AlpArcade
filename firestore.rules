rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isGoogleUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && request.auth.token.email != null;
    }

    function validGame(g) {
      return g in ['tictactoe', 'shooter', 'snake', 'reaction', 'memory'];
    }

    function validScoreData() {
      return request.resource.data.keys().hasAll([
          'game', 'playerName', 'score', 'rankScore', 'userId', 'timestamp'
        ])
        && request.resource.data.game is string
        && validGame(request.resource.data.game)
        && request.resource.data.playerName is string
        && request.resource.data.playerName.size() >= 2
        && request.resource.data.playerName.size() <= 16
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 10000000
        && request.resource.data.rankScore is number
        && request.resource.data.userId == request.auth.uid
        // One document per user per game: scores/{uid}_{game}
        && scoreId == request.auth.uid + '_' + request.resource.data.game;
    }

    // Public leaderboard reads
    match /scores/{scoreId} {
      allow read: if true;

      allow create: if isGoogleUser() && validScoreData();

      allow update: if isGoogleUser()
        && resource.data.userId == request.auth.uid
        && validScoreData();

      allow delete: if false;
    }

    // Username / profile — owner write only
    match /players/{uid} {
      allow read: if true;

      allow create, update: if isGoogleUser()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 2
        && request.resource.data.username.size() <= 16;

      allow delete: if false;
    }
  }
}
