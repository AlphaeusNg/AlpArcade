rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Google sign-in (popup / redirect). Accept provider string or identities map.
    function isGoogleUser() {
      return request.auth != null
        && request.auth.uid is string
        && request.auth.token.email is string
        && request.auth.token.email.size() > 3
        && (
          request.auth.token.firebase.sign_in_provider == 'google.com'
          || request.auth.token.firebase.identities.keys().hasAny(['google.com'])
        );
    }

    function validGame(g) {
      return g in ['tictactoe', 'shooter', 'snake', 'reaction', 'memory'];
    }

    // One best per user per game: scores/{uid}_{gameId}
    function ownsScoreDoc() {
      return request.resource.data.userId == request.auth.uid
        && scoreId == request.auth.uid + '_' + request.resource.data.game;
    }

    function validScoreFields() {
      return request.resource.data.game is string
        && validGame(request.resource.data.game)
        && request.resource.data.playerName is string
        && request.resource.data.playerName.size() >= 2
        && request.resource.data.playerName.size() <= 16
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 10000000
        && request.resource.data.rankScore is number
        && request.resource.data.userId is string;
    }

    match /scores/{scoreId} {
      allow read: if true;

      allow create: if isGoogleUser()
        && validScoreFields()
        && ownsScoreDoc();

      allow update: if isGoogleUser()
        && validScoreFields()
        && ownsScoreDoc()
        && resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    match /players/{uid} {
      allow read: if true;

      allow create, update: if isGoogleUser()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 2
        && request.resource.data.username.size() <= 16;

      allow delete: if false;
    }
  }
}
