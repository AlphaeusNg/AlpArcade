rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Signed-in users only. This app only offers Google sign-in in the UI,
    // so auth.uid is sufficient (strict provider checks break some Google sessions).
    function signedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function validGame(g) {
      return g in ['tictactoe', 'shooter', 'snake', 'reaction', 'memory'];
    }

    // scores/{uid}_{gameId} — one personal best per game
    function ownsScoreWrite() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.game is string
        && validGame(request.resource.data.game)
        && scoreId == request.auth.uid + '_' + request.resource.data.game
        && request.resource.data.playerName is string
        && request.resource.data.playerName.size() >= 1
        && request.resource.data.playerName.size() <= 16
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 10000000
        && request.resource.data.rankScore is number;
    }

    match /scores/{scoreId} {
      allow read: if true;

      allow create: if ownsScoreWrite();

      allow update: if ownsScoreWrite()
        && resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    match /players/{uid} {
      allow read: if true;

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 1
        && request.resource.data.username.size() <= 16;

      allow delete: if false;
    }
  }
}
