rules_version = '2';
// AlpArcade scoreboard rules.
// Deploy from repo root: npx firebase-tools deploy --only firestore:rules
// If vault editor shares this Firebase project, deploy COMBINED rules from:
//   alphaeusng.github.io/firebase/firestore.rules
//
// CRITICAL: path wildcards (e.g. scoreId) MUST be passed into functions.
// Using scoreId inside a top-level function without an argument evaluates false
// → permanent permission-denied even when auth is fine.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.uid is string;
    }

    function validGame(g) {
      return g in ['tictactoe', 'shooter', 'snake', 'reaction', 'memory', 'tapper', 'jubeat', 'breaker'];
    }

    // scoreId is the path wildcard — always pass it in from the match block.
    function validScoreWrite(scoreId) {
      let d = request.resource.data;
      return signedIn()
        && d.userId is string
        && d.userId == request.auth.uid
        && d.game is string
        && validGame(d.game)
        && scoreId == request.auth.uid + '_' + d.game
        && d.playerName is string
        && d.playerName.size() >= 1
        && d.playerName.size() <= 16
        && d.score is number
        && d.score >= 0
        && d.score <= 10000000
        && d.rankScore is number;
    }

    match /scores/{scoreId} {
      allow read: if true;

      allow create: if validScoreWrite(scoreId);

      allow update: if validScoreWrite(scoreId)
        && resource.data.userId == request.auth.uid;

      // Owner may delete own leaderboard row (factory reset / clean slate)
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /players/{uid} {
      allow read: if true;

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 1
        && request.resource.data.username.size() <= 16;

      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // Full account progress (high scores, achievements, XP) — owner only
    match /progress/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if signedIn() && request.auth.uid == uid;
    }
  }
}
